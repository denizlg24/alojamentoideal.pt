{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"remoteCache": {
		"signature": true
	},
	"globalEnv": ["NODE_ENV", "NEXT_PUBLIC_AUTH_URL"],
	"globalPassThroughEnv": [
		"DATABASE_URL",
		"BETTER_AUTH_SECRET",
		"BETTER_AUTH_URL",
		"AUTH_TRUSTED_ORIGINS",
		"GOOGLE_CLIENT_ID",
		"GOOGLE_CLIENT_SECRET",
		"HOSTIFY_API_KEY",
		"HOSTIFY_BASE_URL",
		"HOSTIFY_TIMEOUT_MS",
		"HOSTIFY_MAX_READ_RETRIES",
		"HOSTIFY_RETRY_DELAY_MS",
		"HOSTIFY_ACCOUNT_ID",
		"HOSTIFY_LISTING_INCREMENTAL_BATCH_SIZE",
		"HOSTIFY_LISTING_SYNC_INTERVAL_HOURS",
		"HOSTIFY_LISTING_SYNC_LEASE_MINUTES",
		"HOSTIFY_LISTING_SYNC_MAX_PAGES",
		"HOSTIFY_LISTING_SYNC_PER_PAGE",
		"HOSTIFY_LISTING_STALE_AFTER_HOURS",
		"HOSTIFY_SYNC_CRON_SECRET",
		"CRON_SECRET",
		"LISTING_LLM_ENABLED",
		"OPENAI_API_KEY",
		"OPENAI_LISTING_MODEL",
		"BOKUN_ACCESS_KEY",
		"BOKUN_SECRET_KEY",
		"BOKUN_BASE_URL",
		"BOKUN_TIMEOUT_MS",
		"BOKUN_MAX_READ_RETRIES",
		"BOKUN_RETRY_DELAY_MS",
		"TURBO_REMOTE_CACHE_SIGNATURE_KEY"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": [".next/**", "!.next/cache/**"]
		},
		"typecheck": {
			"dependsOn": ["^typecheck"]
		},
		"test": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
