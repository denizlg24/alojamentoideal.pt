{
	"$schema": "https://turbo.build/schema.json",
	"ui": "tui",
	"remoteCache": {
		"signature": true
	},
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"env": [
				"AUTH_TRUSTED_ORIGINS",
				"BETTER_AUTH_SECRET",
				"BETTER_AUTH_URL",
				"BOKUN_ACCESS_KEY",
				"BOKUN_BASE_URL",
				"BOKUN_MAX_READ_RETRIES",
				"BOKUN_RETRY_DELAY_MS",
				"BOKUN_SECRET_KEY",
				"BOKUN_TIMEOUT_MS",
				"CRON_SECRET",
				"DATABASE_URL",
				"GOOGLE_CLIENT_ID",
				"GOOGLE_CLIENT_SECRET",
				"HOSTIFY_ACCOUNT_ID",
				"HOSTIFY_API_KEY",
				"HOSTIFY_BASE_URL",
				"HOSTIFY_LISTING_STALE_AFTER_HOURS",
				"HOSTIFY_LISTING_SYNC_MAX_PAGES",
				"HOSTIFY_LISTING_SYNC_PER_PAGE",
				"HOSTIFY_MAX_READ_RETRIES",
				"HOSTIFY_RETRY_DELAY_MS",
				"HOSTIFY_SYNC_CRON_SECRET",
				"HOSTIFY_TIMEOUT_MS",
				"LISTING_LLM_ENABLED",
				"OPENAI_API_KEY",
				"OPENAI_LISTING_MODEL",
				"WEB_ORIGIN"
			],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": [".next/**", "!.next/cache/**"]
		},
		"typecheck": {
			"dependsOn": ["^typecheck"]
		},
		"test": {
			"dependsOn": ["^build"],
			"outputs": []
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
