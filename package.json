{
	"name": "alojamentoideal.pt",
	"version": "0.0.1",
	"private": true,
	"scripts": {
		"build": "dotenv -- turbo build",
		"dev": "dotenv -- turbo dev",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check --write .",
		"typecheck": "turbo typecheck",
		"test": "turbo test",
		"prepare": "husky",
		"db:generate": "dotenv -- bun run --filter @workspace/db db:generate",
		"db:migrate": "dotenv -- bun run --filter @workspace/db db:migrate",
		"db:push": "dotenv -- bun run --filter @workspace/db db:push",
		"db:studio": "dotenv -- bun run --filter @workspace/db db:studio",
		"db:up": "docker compose up -d postgres",
		"db:down": "docker compose down",
		"redis:up": "docker compose up -d redis",
		"services:up": "docker compose up -d",
		"services:down": "docker compose down"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@workspace/typescript-config": "workspace:*",
		"dotenv-cli": "^11.0.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"turbo": "^2.9.15",
		"typescript": "^6"
	},
	"packageManager": "bun@1.3.3",
	"engines": {
		"node": ">=20"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	]
}
