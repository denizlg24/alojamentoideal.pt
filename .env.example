# ---------------------------------------------------------------------------
# Alojamento Ideal — environment variables
#
# Sections below reflect which app(s) actually read each variable (verified
# against usage in code, not just where the feature "belongs"):
#   SHARED        — read by @workspace/auth, @workspace/core or @workspace/db,
#                   so both apps/web and apps/admin need it set.
#   WEB ONLY      — apps/web only.
#   ADMIN ONLY    — apps/admin only.
#   BUILD TOOLING — not read by either app at runtime; Turbo/repo-level only.
# ---------------------------------------------------------------------------

# ============================================================================
# SHARED — required by both apps/web and apps/admin
# ============================================================================

# --- Database (required) ---------------------------------------------------
# Postgres connection string used by @workspace/db (client + drizzle).
DATABASE_URL=postgresql://user:password@localhost:5432/alojamento_ideal
# Optional pg pool caps. Runtime defaults to 10; next build defaults to 1 to
# avoid exhausting hosted Postgres connection limits during static generation.
# DATABASE_POOL_MAX=10
# DATABASE_BUILD_POOL_MAX=1

# --- Auth (@workspace/auth) -------------------------------------------------
# getAuthConfig() reads these from process.env for BOTH apps' Better Auth
# instances (apps/web's default mount and apps/admin's getAdminAuth()), even
# though only apps/admin passes an explicit baseURL override.
# Required in production (>=32 chars). Dev falls back to an insecure default.
BETTER_AUTH_SECRET=change-me-to-a-32-char-random-secret
# Comma-separated origins allowed for cross-origin auth. Optional.
AUTH_TRUSTED_ORIGINS=http://localhost:3000
# Google social sign-in. Provider is enabled only when both are set. Only
# apps/web's UI currently exposes a Google sign-in button.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Transactional email (verification + password reset) for both apps' auth
# flows. When RESEND_API_KEY is set, emails are sent via Resend; otherwise
# they are logged to the console.
RESEND_API_KEY=
# RFC 5322 "from" address for auth emails. Defaults to a no-reply address.
# EMAIL_FROM=Alojamento Ideal <no-reply@alojamentoideal.pt>

# --- Stripe secret key (@workspace/core/integrations/stripe) ---------------
# Used by apps/web (checkout PaymentIntents, promotion codes) and by
# apps/admin (manual saga refunds in lib/api/commerce.ts).
STRIPE_SECRET_KEY=

# --- Hostify API client (required) ------------------------------------------
# Client throws if HOSTIFY_API_KEY is missing. Used by apps/web (listings,
# availability, cron sync) and apps/admin (saga accept/cancel actions).
HOSTIFY_API_KEY=your-hostify-api-key
# Optional overrides (sensible defaults applied when unset).
# HOSTIFY_BASE_URL=
# HOSTIFY_TIMEOUT_MS=
# HOSTIFY_MAX_READ_RETRIES=
# HOSTIFY_RETRY_DELAY_MS=

# --- Commerce / reservation saga (optional) --------------------------------
# Read by both apps' commerce code (apps/web and apps/admin lib/api/commerce.ts).
# Safety switch for real provider bookings. Default on (opt-out): set to
# "false" to run the reserve-first saga end-to-end against a no-op gateway so
# checkout, payment, emails and the reconciler all work but NO real Hostify
# reservation/transaction is created. Synthetic holds are saved as "STUB-<uuid>".
# HOSTIFY_BOOKINGS_ENABLED=true
# Auto full refund when a paid order's provider hold cannot be confirmed.
# Default on; set "false" to switch to manual-hold recovery.
# COMMERCE_AUTO_REFUND=true

# --- Hostkit client (guest registration / SIBA + fiscal documents, optional) -
# Hostkit API keys are property-scoped: one key per property, generated in the
# Hostkit app (Properties -> API key). JSON object mapping the Hostify listing
# id to that property's key. Listings without a key are skipped (guest
# submission jobs park and retry; invoicing refuses with a clear error).
# HOSTKIT_API_KEYS={"12345":"hostkit-key-for-listing-12345"}
# HOSTKIT_BASE_URL=https://app.hostkit.pt/api/
# HOSTKIT_TIMEOUT_MS=
# HOSTKIT_MAX_READ_RETRIES=
# HOSTKIT_RETRY_DELAY_MS=
# Optional Hostkit account uid forwarded on every call (legacy accounts).
# HOSTKIT_UID=
# When "true", the guest submission job also files the SIBA bulletin with the
# authorities (sendSIBA). Default off: data is synced to Hostkit and validated
# (validateSIBA) only. Read by both apps' compliance.ts.
# HOSTKIT_SIBA_SEND_ENABLED=false

# --- Redis (@workspace/core/redis) -----------------------------------------
# Connection string for the Redis instance
REDIS_URL=redis://localhost:6379
# Namespace prepended to every key. Defaults to "alojamentoideal".
# REDIS_KEY_PREFIX=alojamentoideal
# Client tuning (sensible defaults applied when unset).
# REDIS_CONNECT_TIMEOUT_MS=10000     # 100-60000
# REDIS_COMMAND_TIMEOUT_MS=5000      # 100-60000
# REDIS_MAX_RETRIES_PER_REQUEST=2    # 0-20

# --- Rate limiting (@workspace/core/rate-limit) ----------------------------
# Redis-backed with an in-memory fallback if Redis is down. All optional.
# Enforced per-route in both apps' API routes.
# Set to "false"/"0"/"off" to disable globally.
RATE_LIMIT_ENABLED=true
# Buckets: points (requests) per window (seconds). Generous defaults shown.
# RATE_LIMIT_DEFAULT_POINTS=300
# RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60
# RATE_LIMIT_AUTH_POINTS=30
# RATE_LIMIT_AUTH_WINDOW_SECONDS=60
# RATE_LIMIT_CRON_POINTS=60
# RATE_LIMIT_CRON_WINDOW_SECONDS=60
# RATE_LIMIT_MUTATION_POINTS=60
# RATE_LIMIT_MUTATION_WINDOW_SECONDS=60
# RATE_LIMIT_CART_READ_POINTS=300
# RATE_LIMIT_CART_READ_WINDOW_SECONDS=60
# RATE_LIMIT_CART_WRITE_POINTS=60
# RATE_LIMIT_CART_WRITE_WINDOW_SECONDS=60
# RATE_LIMIT_CHECKOUT_WRITE_POINTS=20
# RATE_LIMIT_CHECKOUT_WRITE_WINDOW_SECONDS=60

# --- Observability (@workspace/core/observability) -------------------------
# Durable analytics event log in Postgres, written by both apps and read by
# apps/admin's observability page. Set "false"/"0"/"off" to disable.
OBSERVABILITY_ENABLED=true
# Log verbosity for the structured logger: debug | info | warn | error.
# LOG_LEVEL=info
# Optional salt rotating hashed client identifiers (IPs) in the event log.
# OBSERVABILITY_IP_SALT=

# ============================================================================
# WEB APP ONLY (apps/web)
# ============================================================================

# --- Auth origin --------------------------------------------------------
# Web's own Better Auth mount base URL. Defaults to http://localhost:3000
# when unset (this is also the fallback getAuthConfig() uses internally).
BETTER_AUTH_URL=http://localhost:3000
# Auth origin the browser calls. Inlined at build time (NEXT_PUBLIC_*).
# NOTE: apps/admin's browser auth client (packages/auth/src/client.ts) reads
# this SAME key name. Locally both apps load from this one root .env via
# `dotenv -- turbo dev` (see package.json), so running both dev servers
# together inlines this web value into admin's bundle too. On Vercel this is
# a non-issue: web and admin are separate projects, each free to set its own
# NEXT_PUBLIC_AUTH_URL value (see ADMIN APP ONLY section below). If you need
# to run apps/admin's dev server in isolation with a correct browser auth
# origin, override NEXT_PUBLIC_AUTH_URL=http://localhost:3001 for that run.
NEXT_PUBLIC_AUTH_URL=http://localhost:3000

# --- Site metadata / SEO (apps/web/lib/site/config.ts) ---------------------
# Canonical site URL used by the root layout, robots, sitemap and manifest.
# Falls back to https://alojamentoideal.pt when unset.
# NEXT_PUBLIC_SITE_URL=https://alojamentoideal.pt

# --- Stripe (checkout UI + webhook) -----------------------------------------
# Publishable key inlined into the browser bundle (NEXT_PUBLIC_*) so Stripe
# Elements can load on the checkout page. Safe to expose client-side.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret for verifying Stripe events consumed by
# `/api/webhooks/stripe`.
STRIPE_WEBHOOK_SECRET=

# --- Account identity encryption --------------------------------------------
# 32-byte base64 or hex key for encrypted identity document fields. Generate
# with `openssl rand -base64 32` and keep separate from Stripe/API secrets.
ACCOUNT_IDENTITY_ENCRYPTION_KEY=
# Optional comma-separated previous 32-byte keys for decrypting rotated rows.
# ACCOUNT_IDENTITY_ENCRYPTION_KEY_RING=

# --- Listing cache / Hostify sync (optional, web cron) ----------------------
# All have defaults; uncomment to override.
# HOSTIFY_ACCOUNT_ID=default
# HOSTIFY_LISTING_INCREMENTAL_BATCH_SIZE=10   # 1-100
# HOSTIFY_LISTING_SYNC_INTERVAL_HOURS=24      # 1-720
# HOSTIFY_LISTING_SYNC_LEASE_MINUTES=10       # 1-120
# HOSTIFY_LISTING_SYNC_MAX_PAGES=50           # 1-500
# HOSTIFY_LISTING_SYNC_PER_PAGE=50            # 1-100
# HOSTIFY_LISTING_STALE_AFTER_HOURS=24        # 1-720
# Override this with a higher integer to force Hostify listing/pricing/review
# syncs to start a fresh cycle on the next cron poll.
LISTING_SYNC_VERSION=9

# --- Cron auth ---------------------------------------------------------------
# Shared secret guarding cron endpoints. Provider-specific secrets take
# precedence over CRON_SECRET for their route.
CRON_SECRET=change-me-cron-secret
# HOSTIFY_SYNC_CRON_SECRET=
# BOKUN_SYNC_CRON_SECRET=

# --- Listing LLM enrichment (optional) --------------------------------------
# Enabled by default; set to "false"/"0"/"no"/"off" to disable.
# LISTING_LLM_ENABLED=true
OPENAI_API_KEY=
# Model used for listing enrichment. Defaults to gpt-5.5.
OPENAI_LISTING_MODEL=gpt-5.5

# --- Bokun API ---------------------------------------------------------------
# Client throws if access/secret keys are missing when constructed.
BOKUN_ACCESS_KEY=your-bokun-access-key
BOKUN_SECRET_KEY=your-bokun-secret-key
# Activity cache scope and advisory pricing/content locale. All can also be
# controlled from the admin settings panel after the database is migrated.
# BOKUN_ACCOUNT_ID=default
# ACTIVITY_CURRENCY=EUR
# ACTIVITY_LANG=en
# Comma-separated Bokun experience ids shown at /activities, in display order.
# When unset, falls back to the built-in production collection. Set this to the
# account's ids when pointing at a non-production Bokun environment.
# BOKUN_ACTIVITY_IDS=942574,942571,950369
# BOKUN_ACTIVITY_SYNC_INTERVAL_HOURS=24
# BOKUN_ACTIVITY_SYNC_LEASE_MINUTES=10
# BOKUN_ACTIVITY_STALE_AFTER_HOURS=24
# Override this with a higher integer to force Bokun activity cache sync to
# refresh cached experiences on the next cron poll.
ACTIVITY_SYNC_VERSION=1
# Optional overrides.
# BOKUN_BASE_URL=
# BOKUN_TIMEOUT_MS=
# BOKUN_MAX_READ_RETRIES=
# BOKUN_RETRY_DELAY_MS=

# --- Realtime chat (Pusher Channels, optional) ------------------------------
# Server keys used by `/api/realtime/auth` and the order-message publisher.
# When unset, message writes still persist and the UI can poll.
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
# Browser-safe Pusher config for the frontend realtime client.
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# --- Accommodation pricing / availability (optional) ------------------------
# Live Hostify availability and quote responses are cached briefly in Redis.
# ACCOMMODATION_AVAILABILITY_CACHE_TTL_SECONDS=60    # 0-3600
# ACCOMMODATION_QUOTE_CACHE_TTL_SECONDS=300          # 0-3600
# ACCOMMODATION_CURRENCY=EUR
# Candidate cap for date-aware backend search before live availability filter.
# ACCOMMODATION_LIVE_SEARCH_CANDIDATE_LIMIT=100      # 1-500
# Rolling Hostify calendar window stored in the nightly advisory price cache.
# ACCOMMODATION_NIGHTLY_PRICE_SYNC_BATCH_SIZE=10    # 1-100
# ACCOMMODATION_NIGHTLY_PRICE_SYNC_DAYS=540          # 1-730
# ACCOMMODATION_NIGHTLY_PRICE_SYNC_INTERVAL_HOURS=24 # 1-720
# ACCOMMODATION_NIGHTLY_PRICE_SYNC_LEASE_MINUTES=10  # 1-120
# ACCOMMODATION_NIGHTLY_PRICE_SYNC_MAX_PAGES=50      # 1-500
# ACCOMMODATION_NIGHTLY_PRICE_SYNC_MAX_LISTINGS=100  # 1-500

# --- Sentry -----------------------------------------------------------------
# Browser DSN
NEXT_PUBLIC_SENTRY_DSN=
# Server/edge runtime DSN.
SENTRY_DSN=
# Environment tag (defaults to NODE_ENV).
# SENTRY_ENVIRONMENT=
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=
# Trace sampling 0.0-1.0 (default 0.1).
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Source-map upload at build time (optional; CI only).
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# --- Build --------------------------------------------------------------
# Caps Next.js page-data build workers. Defaults to 2.
# NEXT_BUILD_WORKERS=2

# ============================================================================
# ADMIN APP ONLY (apps/admin)
# ============================================================================

# --- Auth origin -------------------------------------------------------------
# Admin app's own Better Auth mount (apps/admin/lib/auth/server.ts). Defaults
# to http://localhost:3001 when unset.
ADMIN_AUTH_URL=http://localhost:3001
# Admin's own browser auth client should use its own origin here
# (http://localhost:3001 in dev, the admin Vercel project's URL in prod) —
# see the NEXT_PUBLIC_AUTH_URL note under WEB APP ONLY above for why this
# can't simply be set to a different value in this one shared local file.

# --- Root admin seed ---------------------------------------------------------
# Runs after migrations in the admin app's Vercel build (see apps/admin/vercel.json)
# and via `bun run db:seed-root-admin`. Promotes the account to admin, creating
# it first when missing. ROOT_ADMIN_PASSWORD (min 8 chars) is only needed for
# that first-time creation.
ROOT_ADMIN_EMAIL=
ROOT_ADMIN_PASSWORD=

# --- Hostkit invoicing kill switch -------------------------------------------
# Kill switch for the admin fiscal-document endpoints. Keep off until the
# business signs off on issuing real invoices through the app.
# HOSTKIT_INVOICING_ENABLED=false

# ============================================================================
# BUILD TOOLING (repo-level; not read by either app at runtime)
# ============================================================================

# --- Turbo Remote Cache (optional) ------------------------------------------
# Signature key for Turbo Remote Cache. Required for remote caching to work.
TURBO_REMOTE_CACHE_SIGNATURE_KEY=
