# ---------------------------------------------------------------------------
# Alojamento Ideal — environment variables
# ---------------------------------------------------------------------------

# --- Database (required) ---------------------------------------------------
# Postgres connection string used by @workspace/db (client + drizzle).
DATABASE_URL=postgresql://user:password@localhost:5432/alojamento_ideal

# --- Auth (@workspace/auth) ------------------------------------------------
# Required in production (>=32 chars). Dev falls back to an insecure default.
BETTER_AUTH_SECRET=change-me-to-a-32-char-random-secret
# Auth base URL. Defaults to http://localhost:3000 when unset.
BETTER_AUTH_URL=http://localhost:3000
# Comma-separated origins allowed for cross-origin auth. Optional.
AUTH_TRUSTED_ORIGINS=http://localhost:3000
# Auth origin the browser calls. Inlined at build time (NEXT_PUBLIC_*).
NEXT_PUBLIC_AUTH_URL=http://localhost:3000
# Google social sign-in. Provider is enabled only when both are set.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Transactional email (verification + password reset). When RESEND_API_KEY is
# set, emails are sent via Resend; otherwise they are logged to the console.
RESEND_API_KEY=
# RFC 5322 "from" address for auth emails. Defaults to a no-reply address.
# EMAIL_FROM=Alojamento Ideal <no-reply@alojamentoideal.pt>

# --- Stripe (@workspace/core/integrations/stripe) --------------------------
# Secret key used to resolve promotion codes/coupons for cart discounts and to
# create checkout PaymentIntents. Discount/payment endpoints return an error
# when this is unset.
STRIPE_SECRET_KEY=
# Publishable key inlined into the browser bundle (NEXT_PUBLIC_*) so Stripe
# Elements can load on the checkout page. Safe to expose client-side.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret for verifying Stripe events. Not yet consumed by a
# webhook route; reserved for the post-payment confirmation workflow.
STRIPE_WEBHOOK_SECRET=

# --- Hostify API (required) ------------------------------------------------
# Client throws if HOSTIFY_API_KEY is missing.
HOSTIFY_API_KEY=your-hostify-api-key
# Optional overrides (sensible defaults applied when unset).
# HOSTIFY_BASE_URL=
# HOSTIFY_TIMEOUT_MS=
# HOSTIFY_MAX_READ_RETRIES=
# HOSTIFY_RETRY_DELAY_MS=

# --- Listing cache / Hostify sync (optional) -------------------------------
# All have defaults; uncomment to override.
# HOSTIFY_ACCOUNT_ID=default
# HOSTIFY_LISTING_INCREMENTAL_BATCH_SIZE=10   # 1-100
# HOSTIFY_LISTING_SYNC_INTERVAL_HOURS=24      # 1-720
# HOSTIFY_LISTING_SYNC_LEASE_MINUTES=10       # 1-120
# HOSTIFY_LISTING_SYNC_MAX_PAGES=50           # 1-500
# HOSTIFY_LISTING_SYNC_PER_PAGE=50            # 1-100
# HOSTIFY_LISTING_STALE_AFTER_HOURS=24        # 1-720

# --- Accommodation pricing / availability (optional) -----------------------
# Live Hostify availability and quote responses are cached briefly in Redis.
# ACCOMMODATION_AVAILABILITY_CACHE_TTL_SECONDS=60    # 0-3600
# ACCOMMODATION_QUOTE_CACHE_TTL_SECONDS=300          # 0-3600
# ACCOMMODATION_CURRENCY=EUR
# Candidate cap for date-aware backend search before live availability filter.
# ACCOMMODATION_LIVE_SEARCH_CANDIDATE_LIMIT=100      # 1-500
# Rolling Hostify calendar window stored in the nightly advisory price cache.
# ACCOMMODATION_NIGHTLY_PRICE_SYNC_BATCH_SIZE=10    # 1-100
# ACCOMMODATION_NIGHTLY_PRICE_SYNC_DAYS=540          # 1-730
# ACCOMMODATION_NIGHTLY_PRICE_SYNC_INTERVAL_HOURS=24 # 1-720
# ACCOMMODATION_NIGHTLY_PRICE_SYNC_LEASE_MINUTES=10  # 1-120
# ACCOMMODATION_NIGHTLY_PRICE_SYNC_MAX_PAGES=50      # 1-500
# ACCOMMODATION_NIGHTLY_PRICE_SYNC_MAX_LISTINGS=100  # 1-500

# --- Cron auth -------------------------------------------------------------
# Shared secret guarding cron endpoints. HOSTIFY_SYNC_CRON_SECRET takes
# precedence over CRON_SECRET for the listing sync route.
CRON_SECRET=change-me-cron-secret
# HOSTIFY_SYNC_CRON_SECRET=

# --- Listing LLM enrichment (optional) -------------------------------------
# Enabled by default; set to "false"/"0"/"no"/"off" to disable.
# LISTING_LLM_ENABLED=true
OPENAI_API_KEY=
# Model used for listing enrichment. Defaults to gpt-5.5.
OPENAI_LISTING_MODEL=gpt-5.5

# --- Bokun API -------------------------------------------------------------
# Client throws if access/secret keys are missing when constructed.
BOKUN_ACCESS_KEY=your-bokun-access-key
BOKUN_SECRET_KEY=your-bokun-secret-key
# Optional overrides.
# BOKUN_BASE_URL=
# BOKUN_TIMEOUT_MS=
# BOKUN_MAX_READ_RETRIES=
# BOKUN_RETRY_DELAY_MS=

# --- Redis (@workspace/core/redis) -----------------------------------------
# Connection string for the Redis instance
REDIS_URL=redis://localhost:6379
# Namespace prepended to every key. Defaults to "alojamentoideal".
# REDIS_KEY_PREFIX=alojamentoideal
# Client tuning (sensible defaults applied when unset).
# REDIS_CONNECT_TIMEOUT_MS=10000     # 100-60000
# REDIS_COMMAND_TIMEOUT_MS=5000      # 100-60000
# REDIS_MAX_RETRIES_PER_REQUEST=2    # 0-20

# --- Rate limiting (@workspace/core/rate-limit) ----------------------------
# Redis-backed with an in-memory fallback if Redis is down. All optional.
# Set to "false"/"0"/"off" to disable globally.
RATE_LIMIT_ENABLED=true
# Buckets: points (requests) per window (seconds). Generous defaults shown.
# RATE_LIMIT_DEFAULT_POINTS=300
# RATE_LIMIT_DEFAULT_WINDOW_SECONDS=60
# RATE_LIMIT_AUTH_POINTS=30
# RATE_LIMIT_AUTH_WINDOW_SECONDS=60
# RATE_LIMIT_CRON_POINTS=60
# RATE_LIMIT_CRON_WINDOW_SECONDS=60
# RATE_LIMIT_MUTATION_POINTS=60
# RATE_LIMIT_MUTATION_WINDOW_SECONDS=60
# RATE_LIMIT_CART_READ_POINTS=300
# RATE_LIMIT_CART_READ_WINDOW_SECONDS=60
# RATE_LIMIT_CART_WRITE_POINTS=60
# RATE_LIMIT_CART_WRITE_WINDOW_SECONDS=60
# RATE_LIMIT_CHECKOUT_WRITE_POINTS=20
# RATE_LIMIT_CHECKOUT_WRITE_WINDOW_SECONDS=60

# --- Observability (@workspace/core/observability) -------------------------
# Durable analytics event log in Postgres. Set "false"/"0"/"off" to disable.
OBSERVABILITY_ENABLED=true
# Log verbosity for the structured logger: debug | info | warn | error.
# LOG_LEVEL=info
# Optional salt rotating hashed client identifiers (IPs) in the event log.
# OBSERVABILITY_IP_SALT=

# --- Sentry (apps/web) -----------------------------------------------------
# Browser DSN
NEXT_PUBLIC_SENTRY_DSN=
# Server/edge runtime DSN.
SENTRY_DSN=
# Environment tag (defaults to NODE_ENV).
# SENTRY_ENVIRONMENT=
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=
# Trace sampling 0.0-1.0 (default 0.1).
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
# Source-map upload at build time (optional; CI only).
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# --- Turbo Remote Cache (optional) --------------------------------------
# Signature key for Turbo Remote Cache. Required for remote caching to work.
TURBO_REMOTE_CACHE_SIGNATURE_KEY=
