{
	"name": "@workspace/db",
	"version": "0.0.0",
	"type": "module",
	"private": true,
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./schema": {
			"types": "./src/schema.ts",
			"default": "./src/schema.ts"
		}
	},
