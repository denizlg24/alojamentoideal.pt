{
	"name": "@workspace/auth",
	"version": "0.0.0",
	"type": "module",
	"private": true,
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./client": {
			"types": "./src/client.ts",
			"default": "./src/client.ts"
		}
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"test": "bun test --pass-with-no-tests",
		"auth:generate": "better-auth generate --config ./src/generate.ts --yes"
	},
	"dependencies": {
		"@workspace/db": "workspace:*",
		"better-auth": "^1.6.20"
	},
	"peerDependencies": {
		"react": "^19"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/node": "^26",
		"@types/react": "^19",
		"@workspace/typescript-config": "workspace:*",
		"react": "19.2.7",
		"typescript": "^6"
	}
}
